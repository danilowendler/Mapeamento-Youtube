# =============================================================
# Mapeamento Inteligente — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar valores reais.
# Referência de segurança: docs/08-seguranca-e-operacao.md §8.2
# =============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (M1+) · Dashboard > Project Settings > API ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOMENTE código de servidor (jobs, webhooks). Jamais NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- YouTube Data API v3 (M2+) · Google Cloud Console ---
# Criar chave com restrição de API (apenas YouTube Data API v3).
YOUTUBE_API_KEY=

# --- Inngest (M2+) · app.inngest.com ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Em desenvolvimento local: OBRIGATÓRIO para os jobs rodarem no Dev
# Server (npx inngest-cli dev). Sem isso, as chaves acima mandam os
# eventos para a nuvem e a pesquisa fica presa na fila. Não usar em prod.
INNGEST_DEV=1

# --- Sentry (M4+) · sentry.io > Project Settings > Client Keys ---
# Vazio = observabilidade desativada (ok em dev local)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Beta fechado (M4+) ---
# "1" = app exige código de convite (gerar: node scripts/create-invites.mjs)
BETA_INVITE_REQUIRED=

# --- Stripe (M7+) · Dashboard > Developers > API keys ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
